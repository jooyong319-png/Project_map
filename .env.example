# ── Google Places API (서버 사이드, Vercel 함수에서 사용) ──
# VITE_ 접두사 없음 → 브라우저에 노출되지 않음 (키 보호)
GOOGLE_PLACES_API_KEY=

# ── Supabase (클라이언트에서 사용하는 공개 anon 키) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 인허가 base 데이터(scripts/buildPlaces.mjs)는 키 불필요 ──
# data.go.kr 에서 '지방행정 인허가' CSV(파일데이터) 다운로드 → 스크립트에 경로만 넘기면 됨.
# (공공누리: 상업적 이용 가능, 출처표시 의무)

# ── 숙박 어필리에이트 (목표 2: AI 코스 근처 숙소 예약 → 수수료) ──
# OTA(부킹/아고다/Travelpayouts) 제휴 승인 후, 제휴사가 준 링크 형식을 그대로 넣으면
# {lat}{lng}{area}{checkin}{checkout} 를 코스 중심 좌표로 채워 예약 딥링크를 만든다.
# 예) STAY_AFF_LINK=https://www.booking.com/searchresults.html?aid=YOUR_AID&latitude={lat}&longitude={lng}
# 미설정 시 코스의 숙박 예약 버튼은 자동 비활성.
STAY_AFF_LINK=

# ── 크론 보호 (api/purge — 21일 지난 구글 캐시 정리) ──
# 설정하면 외부 임의 호출 차단. Vercel 이 자동으로 Bearer 로 붙여줌.
CRON_SECRET=
