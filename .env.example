# ── Google Places API (서버 사이드, Vercel 함수에서 사용) ──
# VITE_ 접두사 없음 → 브라우저에 노출되지 않음 (키 보호)
GOOGLE_PLACES_API_KEY=

# ── Supabase (클라이언트에서 사용하는 공개 anon 키) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 인허가 base 데이터(scripts/buildPlaces.mjs)는 키 불필요 ──
# data.go.kr 에서 '지방행정 인허가' CSV(파일데이터) 다운로드 → 스크립트에 경로만 넘기면 됨.
# (공공누리: 상업적 이용 가능, 출처표시 의무)

# ── 크론 보호 (api/purge — 21일 지난 구글 캐시 정리) ──
# 설정하면 외부 임의 호출 차단. Vercel 이 자동으로 Bearer 로 붙여줌.
CRON_SECRET=
